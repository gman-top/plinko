# Runtime
PORT=4000
NODE_ENV=development

# Origin allowlist — comma-separated list of front-end origins.
# Add your operator's front-end domain in prod.
ALLOWED_ORIGINS=http://localhost:5173,https://gman-top.github.io

# Storage — set to a persistent volume in production.
DATABASE_PATH=./data/casino.sqlite

# Wallet / currency
DEFAULT_CURRENCY=USD
SIGNUP_BONUS_MINOR=100000      # 1,000.00 demo balance
MIN_BET_MINOR=50               # 0.50
MAX_BET_MINOR=10000            # 100.00

# Operator identity (used in audit logs)
OPERATOR_ID=aigostudios-self
OPERATOR_BRAND=PLINKO GONE WILD

# Lifecycle + abuse limits
MAX_DROPS_PER_SEED=10000
DROPS_PER_MINUTE=300
SESSIONS_PER_MINUTE=10
